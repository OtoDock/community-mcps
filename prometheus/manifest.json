{
  "name": "prometheus",
  "label": "Prometheus",
  "description": "Metrics and monitoring queries",
  "version": "1.1.3",
  "category": "community",
  "server": {
    "runtime": "node",
    "transport": "stdio",
    "command": "node",
    "args": ["${mcp_dir}/node_modules/prometheus-mcp/dist/index.mjs", "stdio"],
    "source": "npm:prometheus-mcp@1.1.3"
  },
  "credentials": {
    "type": "none"
  },
  "instances": {
    "delivery": "env",
    "fields": [
      {"key": "PROMETHEUS_URL", "label": "Prometheus URL", "input_type": "url", "default": "http://localhost:9090"}
    ],
    "max_instances": 0
  },
  "config": [],
  "env": {},
  "agent_env": {},
  "assignment_mode": "explicit",
  "exclude_from": [],
  "skills": [],
  "patched": false,
  "patch_note": null
}
