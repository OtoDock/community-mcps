{
  "name": "m365-mcp",
  "label": "Microsoft 365",
  "description": "Microsoft 365 (Mail, Calendar, Teams chat/meetings/transcripts, OneDrive, SharePoint, Contacts) via softeria/ms-365-mcp-server. Bearer-injected HTTP mode — upstream accepts Authorization: Bearer per request so no sidecar needed.",
  "version": "1.0.0",
  "category": "community",
  "server": {
    "runtime": "docker",
    "transport": "streamable_http",
    "docker_compose": "docker-compose.yml",
    "port": 3000,
    "url_template": "http://${docker_mcp_host}:${port}/mcp",
    "image": "ghcr.io/otodock/m365-mcp:1.0.0",
    "source": "docker:m365-mcp"
  },
  "credentials": {
    "type": "per_user",
    "label": "Microsoft 365 Account",
    "description": "Connect your Microsoft work or personal account.",
    "service_account": true,
    "oauth": {
      "provider_id": "microsoft",
      "flows": [
        "authorization_code_pkce",
        "device_code"
      ],
      "base_scopes": [
        "openid",
        "profile",
        "email",
        "offline_access",
        "https://graph.microsoft.com/User.Read"
      ],
      "token_format": {
        "schema": "generic_oauth_v1",
        "filename_pattern": "{account_label}.json"
      },
      "refresh": {
        "strategy": "lazy",
        "min_remaining_seconds": 300
      },
      "supports_multi_account": true,
      "registered_app_required": true,
      "bearer_required": true,
      "proposed_hosts": [
        "localhost"
      ],
      "app_credential": "microsoft-oauth-app",
      "app_credential_fields": [
        {
          "key": "MS_CLIENT_ID",
          "label": "Application (client) ID",
          "input_type": "text",
          "help": "Get from entra.microsoft.com → App registrations → your app → Overview"
        },
        {
          "key": "MS_CLIENT_SECRET",
          "label": "Client Secret",
          "input_type": "password",
          "help": "App registration → Certificates & secrets → New client secret"
        },
        {
          "key": "MS_TENANT_ID",
          "label": "Tenant ID (leave blank for multi-tenant)",
          "input_type": "text",
          "required": false,
          "help": "Paste your Azure AD tenant UUID to lock OAuth to a single organization. Leave blank for multi-tenant ('common' endpoint — accepts any Microsoft personal+work account). Single-tenant is REQUIRED for security-sensitive deploys."
        }
      ],
      "services": [
        {
          "key": "mail",
          "label": "Mail",
          "description": "Read and send email via Outlook / Exchange Online",
          "scopes": [
            "https://graph.microsoft.com/Mail.Read",
            "https://graph.microsoft.com/Mail.Send"
          ]
        },
        {
          "key": "calendar",
          "label": "Calendar",
          "description": "Read and manage calendar events",
          "scopes": [
            "https://graph.microsoft.com/Calendars.ReadWrite"
          ]
        },
        {
          "key": "teams_chat",
          "label": "Teams Messages",
          "description": "Read and send Teams chat messages",
          "scopes": [
            "https://graph.microsoft.com/Chat.ReadWrite"
          ]
        },
        {
          "key": "teams_meetings",
          "label": "Teams Meetings",
          "description": "Schedule, read, and manage Teams online meetings",
          "scopes": [
            "https://graph.microsoft.com/OnlineMeetings.ReadWrite"
          ]
        },
        {
          "key": "teams_transcripts",
          "label": "Teams Transcripts",
          "description": "Read meeting transcripts across the tenant. Requires tenant-admin consent AND a Teams Premium license.",
          "scopes": [
            "https://graph.microsoft.com/OnlineMeetingTranscript.Read.All"
          ],
          "requires_admin_consent": true,
          "capabilities": [
            "reads_org_meeting_transcripts"
          ]
        },
        {
          "key": "onedrive",
          "label": "OneDrive",
          "description": "Read and write files in OneDrive",
          "scopes": [
            "https://graph.microsoft.com/Files.ReadWrite"
          ]
        },
        {
          "key": "sharepoint",
          "label": "SharePoint",
          "description": "Read and write SharePoint sites tenant-wide. Requires tenant-admin consent.",
          "scopes": [
            "https://graph.microsoft.com/Sites.ReadWrite.All"
          ],
          "requires_admin_consent": true
        },
        {
          "key": "contacts",
          "label": "Contacts",
          "description": "Read and manage personal contacts",
          "scopes": [
            "https://graph.microsoft.com/Contacts.ReadWrite"
          ]
        }
      ]
    },
    "webhooks": {
      "available": true,
      "provider_id": "microsoft",
      "signature": {
        "algorithm": "client_state_echo",
        "header": "",
        "per_subscription_secret": true,
        "secret_credential_key": ""
      },
      "url_verification": {
        "kind": "ms_graph_validation_token",
        "request_field": "validationToken",
        "request_source": "query",
        "response_field": "plain_text",
        "response_content_type": "text/plain"
      },
      "registration": {
        "mode": "auto",
        "create": {
          "method": "POST",
          "url_template": "https://graph.microsoft.com/v1.0/subscriptions",
          "headers": {
            "Authorization": "Bearer ${account.access_token}",
            "Content-Type": "application/json"
          },
          "body_template": {
            "changeType": "created,updated",
            "notificationUrl": "${platform.webhook_base}/v1/webhooks/microsoft/${subscription_id}",
            "resource": "${vendor_target}",
            "expirationDateTime": "${expires_at_iso8601}",
            "clientState": "${subscription.signing_secret}",
            "latestSupportedTlsVersion": "v1_2"
          },
          "response_id_path": "id",
          "expected_status": [
            201
          ]
        },
        "delete": {
          "method": "DELETE",
          "url_template": "https://graph.microsoft.com/v1.0/subscriptions/${vendor_subscription_id}",
          "headers": {
            "Authorization": "Bearer ${account.access_token}"
          },
          "expected_status": [
            204,
            404
          ]
        },
        "renew": {
          "method": "PATCH",
          "url_template": "https://graph.microsoft.com/v1.0/subscriptions/${vendor_subscription_id}",
          "headers": {
            "Authorization": "Bearer ${account.access_token}",
            "Content-Type": "application/json"
          },
          "body_template": {
            "expirationDateTime": "${expires_at_iso8601}"
          },
          "expected_status": [
            200
          ],
          "renew_before_seconds": 86400
        },
        "lifetime_seconds": 259200
      },
      "event_catalog": [
        {
          "key": "mail_inbox",
          "label": "Inbox mail changes",
          "description": "Fires when mail in the user's Inbox is created or updated.",
          "required_scopes": [
            "https://graph.microsoft.com/Mail.Read"
          ],
          "resource_contains": "/messages"
        },
        {
          "key": "calendar_events",
          "label": "Calendar events changed",
          "description": "Fires when calendar events are created or updated — including Teams meetings, which live on the calendar.",
          "required_scopes": [
            "https://graph.microsoft.com/Calendars.ReadWrite"
          ],
          "resource_contains": "/events"
        },
        {
          "key": "drive_root",
          "label": "OneDrive root changes",
          "description": "Fires when files in OneDrive root are added or updated.",
          "required_scopes": [
            "https://graph.microsoft.com/Files.ReadWrite"
          ],
          "resource_contains": "drive",
          "vendor_create_fields": {
            "changeType": "updated"
          }
        },
        {
          "key": "contacts",
          "label": "Contacts changed",
          "description": "Fires when personal contacts are created or updated.",
          "required_scopes": [
            "https://graph.microsoft.com/Contacts.ReadWrite"
          ],
          "default_selected": false,
          "resource_contains": "/contacts"
        }
      ],
      "payload_normalization": {
        "event_type_path": "body.changeType",
        "subject": {
          "type_path": "body.resourceData.@odata.type",
          "id_path": "body.resourceData.id"
        },
        "target": {
          "type": "resource",
          "id_path": "body.resource"
        }
      },
      "vendor_target_spec": {
        "kind": "static_list",
        "label": "Resource to subscribe to",
        "help_text": "Microsoft Graph resource for this subscription. `me/...` resources always address the bound account's own user — works for both personal and work accounts (explicit `users/{id}` addressing fails for personal accounts with a user-mismatch error).",
        "static_options": [
          {
            "value": "me/mailFolders('Inbox')/messages",
            "label": "Inbox messages"
          },
          {
            "value": "me/events",
            "label": "Calendar events"
          },
          {
            "value": "me/drive/root",
            "label": "OneDrive root"
          },
          {
            "value": "me/contacts",
            "label": "Contacts"
          }
        ]
      },
      "event_id_field": ""
    }
  },
  "config": [],
  "env": {
    "MCP_PORT": "${platform.mcp_port}"
  },
  "path_env": {},
  "agent_env": {},
  "tool_filter": {
    "arg_name": "--enabled-tools",
    "env_var_name": "ENABLED_TOOLS_FLAG"
  },
  "agent_context": [
    {
      "template": "## Microsoft 365 Account\n\nConnected as **${account.extra.preferred_username}** in tenant `${account.extra.tenant_id}`.\n\nFor scopes ending in `.All` (Teams Transcripts, SharePoint) you also need tenant-admin consent — if a tool returns AADSTS65001, ask your IT admin to grant tenant consent via Admin → MCP Servers → m365-mcp → Grant for whole tenant.",
      "requires": [
        "account.extra.preferred_username"
      ]
    }
  ],
  "exclude_from": [],
  "skills": [],
  "hosted": {
    "oauth_app": {
      "available": true,
      "default_mode": "hosted"
    }
  },
  "patched": false,
  "patch_note": null
}
