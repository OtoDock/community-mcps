{
  "name": "home-assistant",
  "label": "Home Assistant",
  "description": "Smart home control (~97 tools)",
  "version": "7.2.0",
  "category": "community",
  "server": {
    "runtime": "python",
    "transport": "stdio",
    "command": "venv/bin/ha-mcp",
    "args": [],
    "source": "pypi:ha-mcp@7.2.0"
  },
  "credentials": {
    "type": "none"
  },
  "instances": {
    "delivery": "env",
    "fields": [
      {"key": "HOMEASSISTANT_URL", "label": "Home Assistant URL", "input_type": "url", "default": "http://localhost:8123", "required": true},
      {"key": "HOMEASSISTANT_TOKEN", "label": "Long-Lived Token", "input_type": "password", "required": true, "secret": true}
    ],
    "max_instances": 0
  },
  "config": [],
  "env": {},
  "agent_env": {},
  "assignment_mode": "explicit",
  "exclude_from": [],
  "skills": [],
  "patched": false,
  "patch_note": null
}
