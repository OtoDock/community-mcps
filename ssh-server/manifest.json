{
  "name": "ssh-server",
  "label": "SSH",
  "description": "Remote server management via SSH",
  "version": "1.6.0",
  "category": "community",
  "server": {
    "runtime": "node",
    "transport": "stdio",
    "command": "node",
    "args": [
      "${mcp_dir}/node_modules/@fangjunjie/ssh-mcp-server/build/index.js",
      "--config-file",
      "${mcp_dir}/config/hosts.json"
    ],
    "source": "npm:@fangjunjie/ssh-mcp-server@1.6.0"
  },
  "credentials": {
    "type": "none"
  },
  "instances": {
    "delivery": "config_file",
    "fields": [
      {"key": "name", "label": "Host Name", "input_type": "text", "required": true},
      {"key": "host", "label": "Host / IP", "input_type": "text", "required": true},
      {"key": "port", "label": "Port", "input_type": "number", "default": "22"},
      {"key": "username", "label": "Username", "input_type": "text", "required": true},
      {"key": "key_name", "label": "SSH Key", "input_type": "ssh_key_select"}
    ],
    "config_file_arg": "--config-file",
    "config_file_name": "hosts.json",
    "transform": "ssh_hosts"
  },
  "config": [],
  "env": {},
  "agent_env": {},
  "data_dirs": {
    "config": "config/",
    "keys": "keys/"
  },
  "assignment_mode": "explicit",
  "exclude_from": [],
  "skills": [],
  "patched": false,
  "patch_note": null
}
